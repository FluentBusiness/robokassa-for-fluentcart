msgid "<p>Appearance and behavior scenarios of storefront elements</p><p>Configure the appearance and display scenarios of Robokassa branded components on the store front.</p><h3>Robokassa Badge & Widget settings</h3>"
msgstr "<p>Внешний вид и сценарии работы витринных элементов</p><p>Настройте внешний вид и сценарии отображения фирменных компонентов Robokassa на витрине магазина.</p><h3>Настройка Robokassa Badge & Widget</h3>"

msgid "Enable widget or badge"
msgstr "Включить виджет или бейдж"

msgid "After activation the selected Robokassa component will be shown on the product page."
msgstr "После активации на странице товара будет отображаться выбранный компонент Robokassa."

msgid "Default component"
msgstr "Компонент по умолчанию"

msgid "Widget"
msgstr "Виджет"

msgid "Badge"
msgstr "Бейдж"

msgid "Select the component that will be displayed on the product page."
msgstr "Выберите компонент, который будет отображаться на странице товара."

msgid "Color theme"
msgstr "Цветовая тема"

msgid "Light theme"
msgstr "Светлая тема"

msgid "Dark theme"
msgstr "Тёмная тема"

msgid "<h3>Advanced component settings</h3>"
msgstr "<h3>Продвинутые настройки компонентов</h3>"

msgid "Component size"
msgstr "Размер компонента"

msgid "s"
msgstr "s"

msgid "m"
msgstr "m"

msgid "Sets the size attribute. Available options are «s» and «m»."
msgstr "Задаёт значение атрибута size. Доступны варианты «s» и «m»."

msgid "Show Robokassa logo"
msgstr "Показывать логотип Robokassa"

msgid "Controls the showLogo attribute. A value of «false» hides the logo."
msgstr "Управляет атрибутом showLogo. Значение «false» скрывает логотип."

msgid "Offer type"
msgstr "Тип предложения"

msgid "Display both"
msgstr "Отображать оба"

msgid "bnpl"
msgstr "bnpl"

msgid "credit"
msgstr "credit"

msgid "The type attribute value for the Widget component. By default the attribute is not passed, which enables both offer types."
msgstr "Значение атрибута type для компонента «Виджет». По умолчанию атрибут не передаётся, что включает оба типа предложений."

msgid "Border radius"
msgstr "Скругление углов"

msgid "For example: 12px"
msgstr "Например: 12px"

msgid "The borderRadius attribute for the Widget component."
msgstr "Атрибут borderRadius для компонента Виджет."

msgid "Second description line"
msgstr "Вторая строка описания"

msgid "Corresponds to hasSecondLine attribute (Only for widget & size: m)."
msgstr "Соответствует атрибуту hasSecondLine (Только для widget & size: m)."

msgid "Description position"
msgstr "Позиция описания"

msgid "Left"
msgstr "Слева"

msgid "Right"
msgstr "Справа"

msgid "The descriptionPosition attribute value for the widget only."
msgstr "Значение атрибута descriptionPosition только для виджета."

msgid "Notifications"
msgstr "Оповещение"

msgid "<p>SMS scenarios and templates for customers</p><h3>SMS settings</h3><p>Manage texts and sending conditions for SMS messages to your store customers.</p><p>The message body supports the following placeholders:</p><p>{address} — delivery address.<br/>{fio} — customer full name<br/>{order_number} — order number."
msgstr "<p>Сценарий и шаблоны SMS для клиентов</p><h3>Настройки SMS</h3><p>Управляйте текстами и условиями отправки SMS-сообщений для покупателей вашего магазина.</p><p>В теле сообщения доступны следующие метки:</p><p>{address} — адрес доставки заказа.<br/>{fio} — ФИО покупателя<br/>{order_number} — номер заказа."

msgid "SMS transliteration"
msgstr "Транслитерация SMS сообщений"

msgid "Enable/Disable"
msgstr "Включить/Выключить"

msgid "SMS payment transliteration"
msgstr "Транслитерация SMS сообщений"

msgid "Notification of successful payment"
msgstr "Уведомление об успешной оплате"

msgid "Notification text for successful payment"
msgstr "Текст сообщения при успешной оплате"

msgid "Notification of order completion"
msgstr "Уведомление о завершении заказа"

msgid "Notification text for order completion"
msgstr "Текст сообщения при завершении заказа"

msgid "Registration"
msgstr "Регистрация"

msgid "Register with Robokassa"
msgstr "Регистрация в Robokassa"

msgid "Submit an application to connect Robokassa directly from the admin panel and start accepting payments without extra steps."
msgstr "Подайте заявку на подключение Robokassa прямо из панели управления и начните принимать платежи без лишних действий."
